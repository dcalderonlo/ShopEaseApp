@page "/register"
@attribute [AllowAnonymous]
@inject RegisterHandler Handler
@inject NavigationManager Nav

<h1>Register</h1>

<EditForm Model="@_form" OnValidSubmit="HandleRegister" FormName="registerForm">
    <DataAnnotationsValidator />
    <div><input @bind="_form.FirstName" placeholder="First Name" /></div>
    <div><input @bind="_form.LastName" placeholder="Last Name" /></div>
    <div><input @bind="_form.Email" placeholder="Email" /></div>
    <div><input type="password" @bind="_form.Password" placeholder="Password" /></div>
    <button type="submit">Register</button>
</EditForm>

@if (_error is not null)
{
    <p style="color:red">@_error</p>
}

@code {
    private sealed class RegisterForm
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }

    private readonly RegisterForm _form = new();
    private string? _error;

    private async Task HandleRegister()
    {
        var request = new RegisterRequest(_form.FirstName, _form.LastName, _form.Email, _form.Password);
        var (success, _, errors) = await Handler.HandleAsync(request);
        if (success)
            Nav.NavigateTo("/login");
        else
            _error = string.Join(", ", errors);
    }
}
