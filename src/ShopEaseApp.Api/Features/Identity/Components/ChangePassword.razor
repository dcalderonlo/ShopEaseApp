@page "/change-password"
@attribute [Authorize]
@using ShopEaseApp.Api.Features.Identity.ChangePassword
@using Microsoft.AspNetCore.Identity
@using ShopEaseApp.Api.Infrastructure.Data
@inject ChangePasswordHandler Handler
@inject NavigationManager Nav
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthState

<h3>Change Password</h3>

<EditForm Model="@_model" OnValidSubmit="HandleChange" FormName="changePasswordForm">
    <DataAnnotationsValidator />
    <div><input type="password" @bind-value="_model.CurrentPassword" placeholder="Current Password" /></div>
    <div><input type="password" @bind-value="_model.NewPassword" placeholder="New Password (min 6 chars)" /></div>
    <button type="submit">Change Password</button>
</EditForm>

@if (_error is not null)
{
    <p style="color:red">@_error</p>
}

@if (_success)
{
    <p style="color:green">Password changed! Redirecting...</p>
}

@code {
    private sealed class ChangePasswordForm
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
    }

    private readonly ChangePasswordForm _model = new();
    private string? _error;
    private bool _success;

    private async Task HandleChange()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            _error = "Not authenticated.";
            return;
        }

        var (success, error) = await Handler.HandleAsync(
            user, new ChangePasswordRequest(_model.CurrentPassword, _model.NewPassword));

        if (success)
        {
            _success = true;
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            _error = error;
        }
    }
}
