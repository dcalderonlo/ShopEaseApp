@page "/user/dashboard"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ShopEaseApp.Api.Features.Catalog.Components
@using ShopEaseApp.Api.Features.Orders.Components

<UserTopBar />

<main class="pt-24 pb-xl hero-gradient min-h-screen">
    <div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop space-y-xl">

        @* ── Hero ── *@
        <section class="space-y-sm">
            <div class="inline-flex items-center px-4 py-2 rounded-full
                        bg-primary-container/10 text-primary font-label-sm uppercase tracking-wider">
                Member Dashboard
            </div>
            <h1 class="font-display-lg-mobile md:font-display-lg
                       text-display-lg-mobile md:text-display-lg max-w-2xl leading-tight">
                Welcome back, @_firstName!
                Ready to discover something new today?
            </h1>
            <p class="text-body-lg text-outline max-w-lg">
                Explore personalized recommendations and track your latest updates all in one place.
            </p>
        </section>

        @* ── Quick Actions ── *@
        <section>
            <h2 class="font-headline-md text-headline-md mb-md">Quick Actions</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-md">
                <QuickActionCard Href="/"
                                 Icon="grid_view"
                                 IconBgClass="bg-primary-container text-on-primary-container"
                                 Title="Browse Catalog"
                                 Subtitle="Explore all products" />
                <QuickActionCard Href="/orders"
                                 Icon="local_shipping"
                                 IconBgClass="bg-secondary-container text-on-secondary-container"
                                 Title="Track Orders"
                                 Subtitle="@($"{_pendingOrders} order(s) active")" />
                <QuickActionCard Href="/cart"
                                 Icon="shopping_cart"
                                 IconBgClass="bg-tertiary-container text-on-tertiary-container"
                                 Title="My Cart"
                                 Subtitle="Review items" />
            </div>
        </section>

        @* ── Recommended Products ── *@
        <section class="space-y-lg">
            <div class="flex justify-between items-end">
                <div>
                    <h2 class="font-headline-md text-headline-md">Recommended for You</h2>
                    <p class="font-body-md text-outline">Latest products from our catalog</p>
                </div>
                <a href="/" class="text-primary font-bold hover:underline">View All</a>
            </div>

            @if (_products is null)
            {
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-md">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="bg-surface-container-low rounded-xl aspect-square animate-pulse"></div>
                    }
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-md">
                    @foreach (var p in _products.Take(4))
                    {
                        <ProductCard ProductId="@p.Id"
                                     Name="@p.Name"
                                     Category="@p.CategoryName"
                                     ImageUrl="@p.ImageUrls.FirstOrDefault()"
                                     Price="@(p.Variants.FirstOrDefault()?.Price ?? 0)"
                                     OnClick="GoToProduct" />
                    }
                </div>
            }
        </section>

        @* ── Recent Orders ── *@
        <section class="space-y-md">
            <h2 class="font-headline-md text-headline-md">Recent Orders</h2>

            @if (_orders is null)
            {
                <p class="text-outline font-body-md">Loading orders...</p>
            }
            else if (!_orders.Any())
            {
                <div class="bg-surface-container-lowest rounded-xl p-lg text-center border border-outline-variant/30">
                    <span class="material-symbols-outlined text-[48px] text-outline">receipt_long</span>
                    <p class="font-body-md text-outline mt-md">No orders yet.</p>
                    <a href="/" class="text-primary font-bold hover:underline mt-sm inline-block">Start shopping</a>
                </div>
            }
            else
            {
                <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/30 overflow-hidden">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-surface-container-low">
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Order #</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Date</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Status</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/20">
                            @foreach (var order in _orders.Take(5))
                            {
                                <tr class="hover:bg-surface-container-low/50 transition-colors">
                                    <td class="px-md py-md font-bold text-on-surface">#@order.Id</td>
                                    <td class="px-md py-md text-on-surface-variant">@order.CreatedAt.ToString("MMM d, yyyy")</td>
                                    <td class="px-md py-md">
                                        <span class="px-sm py-1 rounded-full text-label-sm font-bold
                                                     @(order.Status == "Confirmed"
                                                         ? "bg-tertiary/10 text-tertiary"
                                                         : "bg-primary/10 text-primary")">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td class="px-md py-md text-right font-bold text-primary">$@order.Total.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (_orders.Count() > 5)
                    {
                        <div class="px-md py-sm bg-surface-container-low text-center">
                            <a href="/orders" class="text-primary font-label-sm font-bold hover:underline">
                                View all @_orders.Count() orders
                            </a>
                        </div>
                    }
                </div>
            }
        </section>

        @* ── Member Perks Banner ── *@
        <section class="relative overflow-hidden bg-primary-container rounded-xl
                        p-lg md:p-xl flex flex-col md:flex-row items-center
                        justify-between gap-lg shadow-lg">
            <div class="absolute -right-20 -top-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
            <div class="absolute -left-10 -bottom-10 w-60 h-60 bg-secondary/10 rounded-full blur-3xl"></div>

            <div class="relative z-10 space-y-md text-center md:text-left max-w-xl">
                <div class="inline-block bg-white text-primary font-bold px-4 py-1 rounded-full font-label-sm">
                    MEMBER EXCLUSIVE
                </div>
                <h2 class="font-display-lg-mobile md:font-display-lg
                           text-display-lg-mobile md:text-display-lg leading-none text-on-primary-container">
                    Enjoy 20% off your next order
                </h2>
                <p class="text-body-lg text-on-primary-container/80">
                    Use code <span class="font-bold text-white">SHOPJOY20</span> at checkout for extra
                    savings and free express shipping this week.
                </p>
            </div>
            <div class="relative z-10">
                <a href="/"
                   class="bg-white text-primary font-bold px-lg py-md rounded-full shadow-lg
                          hover:scale-105 transition-transform active:scale-95 whitespace-nowrap inline-block">
                    Claim Discount Now
                </a>
            </div>
        </section>

    </div>
</main>

@* ── Footer ── *@
<footer class="bg-surface-container-lowest border-t border-outline-variant/30
               px-margin-mobile md:px-margin-desktop py-xl">
    <div class="max-w-7xl mx-auto w-full flex flex-col md:flex-row justify-between items-center gap-md">
        <div class="flex flex-col md:flex-row items-center gap-md md:gap-lg">
            <span class="font-headline-md text-headline-md font-bold text-primary">EaseShop</span>
            <nav class="flex gap-md">
                <a href="#" class="font-label-sm text-on-surface-variant hover:text-primary transition-colors uppercase tracking-wider">Privacy</a>
                <a href="#" class="font-label-sm text-on-surface-variant hover:text-primary transition-colors uppercase tracking-wider">Terms</a>
                <a href="#" class="font-label-sm text-on-surface-variant hover:text-primary transition-colors uppercase tracking-wider">Contact</a>
            </nav>
        </div>
        <p class="font-label-sm text-outline">© 2026 EaseShop. All rights reserved.</p>
    </div>
</footer>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [Inject] private ProductHandler ProductHandler { get; set; } = null!;
    [Inject] private OrderHandler OrderHandler { get; set; } = null!;
    [Inject] private NavigationManager Nav { get; set; } = null!;

    private string _firstName = "there";
    private IEnumerable<ProductResponse>? _products;
    private IEnumerable<OrderResponse>? _orders;
    private int _pendingOrders = 0;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) return;

        var authState = await AuthState;
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            Nav.NavigateTo("/login", replace: true);
            return;
        }

        _firstName = user.FindFirstValue(ClaimTypes.GivenName)
                    ?? user.FindFirstValue(ClaimTypes.Name)
                    ?? "there";

        var userId = user.FindFirstValue(ClaimTypes.NameIdentifier)!;

        // Secuencial en lugar de paralelo — mismo DbContext no soporta concurrencia
        _products = await ProductHandler.GetAllAsync();
        _orders   = await OrderHandler.GetCustomerHistoryAsync(userId);
        _pendingOrders = _orders.Count(o => o.Status == "Pending");
    }

    private void GoToProduct(int id) => Nav.NavigateTo($"/product/{id}");
}
