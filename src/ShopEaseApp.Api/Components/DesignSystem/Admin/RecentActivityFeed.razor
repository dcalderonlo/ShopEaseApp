@* Organism: Recent activity timeline *@
@using ShopEaseApp.Api.Components.DesignSystem.Molecules

<div class="glass-card p-lg rounded-xl shadow-sm flex flex-col">
    <h4 class="font-headline-md text-headline-md mb-lg">Recent Activity</h4>
    <div class="flex-1 space-y-md">
        @if (!Items.Any())
        {
            <p class="font-body-md text-outline">No recent activity.</p>
        }
        else
        {
            @foreach (var (item, i) in Items.Select((a, i) => (a, i)))
            {
                <ActivityFeed Title="@item.Title"
                              Subtitle="@item.Subtitle"
                              DotClass="@item.DotClass"
                              HoverClass="@item.HoverClass"
                              IsLast="@(i == Items.Count - 1)" />
            }
        }
    </div>
    <button class="mt-lg w-full text-center py-sm font-label-sm text-primary
                   hover:bg-primary/5 rounded-full transition-colors">
        View All Activities
    </button>
</div>

@code {
    [Parameter] public List<ActivityItemData> Items { get; set; } = [];

    public record ActivityItemData(
        string Title,
        string Subtitle,
        string DotClass,
        string HoverClass);
}
