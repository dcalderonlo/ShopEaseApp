@page "/admin/categories"
@attribute [Authorize(Roles = "Admin")]
@using ShopEaseApp.Api.Features.Admin.Dashboard
@using ShopEaseApp.Api.Features.Catalog.Categories
@using ShopEaseApp.Api.Components.DesignSystem.Atoms
@using ShopEaseApp.Api.Components.DesignSystem.Admin

<AdminSidebar CurrentPage="categories" />

<main class="lg:ml-64 min-h-screen transition-all pt-20 lg:pt-0">
    <div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-lg">

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-md mb-lg">
            <div>
                <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-xs">Manage Categories</h2>
                <p class="text-on-surface-variant font-body-md">Manage your store's product structure and hierarchy.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-md mb-md">
            <StatCard Label="TOTAL CATEGORIES" Value="@_totalCategories.ToString()" ValueClass="text-primary" />
            <StatCard Label="TOTAL PRODUCTS" Value="@_totalProducts.ToString()" ValueClass="text-tertiary" />
        </div>

        <div class="flex justify-end mb-md">
            <button class="flex items-center justify-center gap-xs bg-primary text-on-primary px-md py-2.5 rounded-full text-label-sm font-bold shadow-soft hover:shadow-lg hover:scale-[1.02] active:scale-95 transition-all"
                    @onclick="() => { _editingCategory = null; _showModal = true; }">
                <span class="material-symbols-outlined">add_circle</span>Add New Category
            </button>
        </div>

        <div class="bg-surface-container-lowest rounded-lg shadow-soft overflow-hidden border border-outline-variant">
            <div class="p-md border-b border-outline-variant flex justify-between items-center gap-md">
                <div class="relative w-full max-w-md">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">search</span>
                    <input @bind="_search" @bind:event="oninput"
                           class="w-full pl-12 pr-4 py-2.5 bg-surface-container-low border-none rounded-full focus:ring-2 focus:ring-primary-container text-body-md transition-all"
                           placeholder="Search categories..." type="text" />
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container text-on-surface-variant">
                            <th class="px-md py-4 font-label-sm text-label-sm uppercase tracking-wider text-outline">Name</th>
                            <th class="px-md py-4 font-label-sm text-label-sm uppercase tracking-wider text-outline">Description</th>
                            <th class="px-md py-4 font-label-sm text-label-sm uppercase tracking-wider text-outline text-center">Products</th>
                            <th class="px-md py-4 font-label-sm text-label-sm uppercase tracking-wider text-outline text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @foreach (var cat in _filteredCategories)
                        {
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="px-md py-5 font-body-md font-bold text-on-surface">@cat.Name</td>
                                <td class="px-md py-5 text-body-md text-outline max-w-xs truncate">@cat.Description</td>
                                <td class="px-md py-5 text-center">
                                    <span class="inline-block px-3 py-1 bg-primary-fixed-dim text-on-primary-fixed rounded-full text-label-sm font-bold">@cat.ProductCount</span>
                                </td>
                                <td class="px-md py-5 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button class="p-2 text-on-surface-variant hover:text-primary hover:bg-primary-container/10 rounded-lg transition-all"
                                                @onclick="() => EditCategory(cat)">
                                            <span class="material-symbols-outlined">edit</span>
                                        </button>
                                        <button class="p-2 text-on-surface-variant hover:text-error hover:bg-error-container/10 rounded-lg transition-all"
                                                @onclick="() => DeleteCategory(cat)">
                                            <span class="material-symbols-outlined">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-md py-4 bg-surface-container flex items-center justify-between">
                <p class="text-label-sm text-outline">Showing @_filteredCategories.Count of @_categories.Count categories</p>
            </div>
        </div>

        <footer class="w-full py-lg mt-xl flex justify-center border-t border-outline-variant/30">
            <span class="font-label-sm text-label-sm text-on-surface-variant">© 2026 EasyShop. Energetic Simplicity.</span>
        </footer>
    </div>
</main>

@if (_showModal)
{
    <div class="fixed inset-0 z-[100] bg-surface/90 backdrop-blur-sm flex items-center justify-center p-4"
         @onclick="() => _showModal = false">
        <div class="w-full max-w-md glass-card rounded-xl shadow-xl border border-outline-variant/30 p-lg"
             @onclick:stopPropagation="true">
            <h3 class="font-headline-md text-headline-md text-on-surface mb-lg">
                @(_editingCategory is null ? "Create Category" : "Edit Category")
            </h3>
            <div class="space-y-md">
                <div>
                    <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Name</label>
                    <input @bind="_formName" @bind:event="oninput"
                           class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md mt-2"
                           placeholder="e.g. Electronics" type="text" />
                </div>
                <div>
                    <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Description</label>
                    <textarea @bind="_formDescription" @bind:event="oninput"
                              class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md resize-none mt-2"
                              placeholder="Brief description..." rows="3"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <p class="text-error font-body-md">@_formError</p>
                }
                <div class="flex gap-sm justify-end pt-md border-t border-outline-variant">
                    <button class="px-md py-sm rounded-xl font-body-md text-on-surface-variant bg-surface-container-low border border-outline-variant"
                            @onclick="() => _showModal = false">Cancel</button>
                    <button class="px-md py-sm rounded-xl font-body-md text-on-primary bg-primary"
                            @onclick="SaveCategory">
                        @(_editingCategory is null ? "Create" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CategoryRow> _categories = [];
    private List<CategoryRow> _filteredCategories => string.IsNullOrWhiteSpace(_search)
        ? _categories
        : _categories.Where(c => c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                               || (c.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)).ToList();
    private string _search = "";
    private int _totalCategories => _categories.Count;
    private int _totalProducts => _categories.Sum(c => c.ProductCount);

    private bool _showModal;
    private CategoryRow? _editingCategory;
    private string _formName = "";
    private string _formDescription = "";
    private string? _formError;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _categories = (await CategoryHandler.GetAllAsync())
            .Select(c => new CategoryRow { Id = c.Id, Name = c.Name, Description = c.Description }).ToList();
        StateHasChanged();
    }

    private void EditCategory(CategoryRow cat)
    {
        _editingCategory = cat;
        _formName = cat.Name;
        _formDescription = cat.Description ?? "";
        _formError = null;
        _showModal = true;
    }

    private async Task DeleteCategory(CategoryRow cat)
    {
        var (success, error) = await CategoryHandler.DeleteAsync(cat.Id);
        if (!success) return;
        await LoadData();
    }

    private async Task SaveCategory()
    {
        _formError = null;
        if (string.IsNullOrWhiteSpace(_formName)) { _formError = "Name is required."; return; }

        if (_editingCategory is null)
        {
            await CategoryHandler.CreateAsync(new CreateCategoryRequest(_formName, _formDescription));
        }
        else
        {
            await CategoryHandler.UpdateAsync(_editingCategory.Id, new UpdateCategoryRequest(_formName, _formDescription));
        }

        _showModal = false;
        await LoadData();
    }

    public class CategoryRow
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public int ProductCount { get; set; }
    }

    [Inject] private CategoryHandler CategoryHandler { get; set; } = null!;
}
