@page "/admin/categories"
@attribute [Authorize(Roles = "Admin")]
@using ShopEaseApp.Api.Features.Admin.Dashboard
@using ShopEaseApp.Api.Features.Catalog.Categories
@using ShopEaseApp.Api.Components.DesignSystem.Atoms
@using ShopEaseApp.Api.Components.DesignSystem.Admin

<AdminSidebar CurrentPage="categories" />
<AdminTopBar />

<main class="lg:ml-64 min-h-screen transition-all pt-16 lg:pt-0">
    <div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-lg">

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-md mb-lg">
            <div>
                <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-xs">Manage
                    Categories</h2>
                    <p class="text-on-surface-variant font-body-md">Manage your store's product structure and hierarchy.</p>
            </div>
        </div>

        @* <div class="grid grid-cols-1 md:grid-cols-2 gap-md mb-md"> *@
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md mb-xl">
            @* <StatCard Label="TOTAL CATEGORIES" Value="@_categories.Count.ToString()" ValueClass="text-primary" />
        <StatCard Label="TOTAL PRODUCTS" Value="@_totalProducts.ToString()" ValueClass="text-tertiary" /> *@
            <StatCard Label="TOTAL CATEGORIES" Value="@_categories.Count.ToString()" ValueClass="text-on-surface"
                        StatIcon="category" StatIconBgClass="bg-primary-fixed-dim text-primary" />

            <StatCard Label="TOTAL PRODUCTS" Value="@_totalProducts.ToString()" ValueClass="text-on-surface"
                        StatIcon="inventory_2" StatIconBgClass="bg-tertiary-fixed-dim text-tertiary" />

            <StatCard Label="TOP SELLING" Value="@_topCategory" ValueClass="text-on-surface" StatIcon="trending_up"
                        StatIconBgClass="bg-secondary-fixed-dim text-secondary" />
        </div>

        <div class="flex justify-end mb-md">
            <button class="h-12 px-md bg-primary text-on-primary rounded-full shadow-lg
                flex items-center justify-center gap-sm
                active:scale-95 transition-transform hover:opacity-90"
                    @onclick="() => { _editingCategory = null; _showModal = true; }">
                <span class="material-symbols-outlined text-[24px]">add</span>
                <span class="font-label-sm text-label-sm">Add New Category</span>
            </button>
        </div>

        <CategoriesTable Items="@_categories" OnEdit="EditCategory" OnDelete="DeleteCategory" />

        <footer class="w-full py-lg mt-xl flex justify-center border-t border-outline-variant/30">
            <span class="font-label-sm text-label-sm text-on-surface-variant">© 2026 EasyShop. Energetic
                Simplicity.</span>
        </footer>

            
        <AdminCategoryEditModal Category="@_editingCategory" Visible="@_showModal" OnClose="() => _showModal = false"
                                OnCreate="HandleCreate" OnUpdate="HandleUpdate" />

        <AdminCategoryDeleteModal Category="@_deletingCategory" Visible="@_showDeleteModal"
                                    OnClose="() => _showDeleteModal = false" OnConfirm="HandleDeleteConfirmed" />
    </div>
</main>

@code {
    private List<AdminCategoryItem> _categories = [];
    private int _totalProducts => _categories.Sum(c => c.ProductCount);
    private bool _showModal;
    private bool _showDeleteModal;
    private AdminCategoryItem? _editingCategory;
    private AdminCategoryItem? _deletingCategory;
    private string _topCategory = "—";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _categories = await CatHandler.GetCategoriesAsync();
        StateHasChanged();
        _topCategory = _categories
        .OrderByDescending(c => c.ProductCount)
        .FirstOrDefault()?.Name ?? "—";
    }

    private void EditCategory(AdminCategoryItem cat) { _editingCategory = cat; _showModal = true; }

    private void DeleteCategory(AdminCategoryItem cat)
    {
        _deletingCategory = cat;
        _showDeleteModal = true;
    }

    private async Task HandleDeleteConfirmed(AdminCategoryItem cat)
    {
        await CatHandler.DeleteAsync(cat.Id);
        _showDeleteModal = false;
        await LoadData();
    }

    private async Task HandleCreate(CreateCategoryRequest req)
    {
        await CatHandler.CreateAsync(req);
        _showModal = false;
        await LoadData();
    }

    private async Task HandleUpdate((int Id, UpdateCategoryRequest Request) args)
    {
        await CatHandler.UpdateAsync(args.Id, args.Request);
        _showModal = false;
        await LoadData();
    }

    [Inject] private CategoryHandler CatHandler { get; set; } = null!;
}
