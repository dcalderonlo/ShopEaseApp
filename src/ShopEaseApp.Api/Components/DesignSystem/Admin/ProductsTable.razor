@* Organism: Products table — thumbnail, search, status badges, actions, pagination *@
@using ShopEaseApp.Api.Features.Admin.Dashboard

<div class="bg-surface rounded-lg raised-card border border-outline-variant/30 overflow-hidden">

    @* Search & actions bar *@
    <div class="p-md border-b border-outline-variant/20 flex flex-col md:flex-row md:items-center justify-between gap-md">
        <div class="relative max-w-md w-full">
            <span class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline">search</span>
            <input @bind="SearchTerm" @bind:event="oninput"
                   class="w-full pl-xl pr-md py-sm bg-surface-container-low border-none
                          rounded-xl font-body-md focus:ring-2 focus:ring-primary transition-all"
                   placeholder="Search products, categories..." type="text" />
        </div>
        <div class="flex items-center gap-sm">
            <button class="flex items-center gap-xs px-lg py-sm border border-outline rounded-full
                           text-label-sm font-medium text-on-surface-variant
                           hover:bg-surface-container-high transition-all">
                <span class="material-symbols-outlined">filter_list</span>
                <span>Filter</span>
            </button>
            <button class="flex items-center gap-xs px-lg py-sm border border-outline rounded-full
                           text-label-sm font-medium text-on-surface-variant
                           hover:bg-surface-container-high transition-all">
                <span class="material-symbols-outlined">download</span>
                <span>Export</span>
            </button>
        </div>
    </div>

    @* Table *@
    <div class="overflow-x-auto custom-scrollbar">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low">
                    <th class="px-md py-sm font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Product Name</th>
                    <th class="px-md py-sm font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Category</th>
                    <th class="px-md py-sm font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Stock Level</th>
                    <th class="px-md py-sm font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Status</th>
                    <th class="px-md py-sm font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider text-right">Price</th>
                    <th class="px-md py-sm font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/20">
                @foreach (var item in PagedProducts)
                {
                    <tr class="group hover:bg-surface-container-low/50 transition-colors">
                        <td class="px-md py-md">
                            <div class="flex items-center gap-md">
                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <div class="w-12 h-12 rounded-lg bg-cover bg-center shrink-0"
                                         style="background-image: url('@item.ThumbnailUrl')">
                                    </div>
                                }
                                else
                                {
                                    <div class="w-12 h-12 rounded-lg bg-surface-container flex items-center
                                                justify-center shrink-0 border border-outline-variant/30">
                                        <span class="material-symbols-outlined text-outline">image</span>
                                    </div>
                                }
                                <span class="font-bold text-on-surface">@item.ProductName</span>
                            </div>
                        </td>
                        <td class="px-md py-md text-on-surface-variant">@item.CategoryName</td>
                        <td class="px-md py-md font-bold @(item.Status == "Low Stock" ? "text-secondary" : "")">@item.Stock</td>
                        <td class="px-md py-md">
                            <StatusBadge Label="@item.Status" />
                        </td>
                        <td class="px-md py-md text-right font-bold text-primary">$@item.Price.ToString("F2")</td>
                        <td class="px-md py-md">
                            <div class="flex justify-center gap-xs">
                                <button class="p-xs text-on-surface-variant hover:text-primary transition-all active:scale-90"
                                        @onclick="() => OnEditItem(item)">
                                    <span class="material-symbols-outlined">edit</span>
                                </button>
                                <button class="p-xs text-on-surface-variant hover:text-error transition-all active:scale-90"
                                        @onclick="() => OnDeleteItem(item)">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    <div class="p-md bg-surface-container-low flex items-center justify-between">
        <span class="font-label-sm text-label-sm text-on-surface-variant">
            Showing @PageStart to @PageEnd of @FilteredCount entries
        </span>
        @if (TotalPages > 1)
        {
            <div class="flex gap-xs">
                <button class="w-10 h-10 flex items-center justify-center rounded-xl
                               hover:bg-surface-variant text-on-surface-variant transition-all"
                        @onclick="PrevPage" disabled="@(_currentPage == 1)">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                @for (int i = 1; i <= TotalPages; i++)
                {
                    var pageNumber = i;
                    <button class="w-10 h-10 flex items-center justify-center rounded-xl transition-all
                                   @(_currentPage == pageNumber
                                       ? "bg-primary text-on-primary font-bold"
                                       : "hover:bg-surface-variant text-on-surface-variant")"
                            @onclick="() => SetPage(pageNumber)">
                        @pageNumber
                    </button>
                }
                <button class="w-10 h-10 flex items-center justify-center rounded-xl
                               hover:bg-surface-variant text-on-surface-variant transition-all"
                        @onclick="NextPage" disabled="@(_currentPage == TotalPages)">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IEnumerable<AdminProductItem> Items { get; set; } = [];
    [Parameter] public EventCallback<AdminProductItem> OnEdit { get; set; }
    [Parameter] public EventCallback<AdminProductItem> OnDelete { get; set; }

    private const int PageSize = 5;
    private int _currentPage = 1;
    private string _searchTerm = "";

    private string SearchTerm
    {
        get => _searchTerm;
        set { _searchTerm = value; _currentPage = 1; }
    }

    private List<AdminProductItem> FilteredProducts =>
        string.IsNullOrWhiteSpace(SearchTerm)
            ? Items.ToList()
            : Items.Where(p =>
                (p.ProductName?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                || (p.CategoryName?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false)).ToList();

    private int FilteredCount => FilteredProducts.Count;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCount / (double)PageSize));
    private int PageStart => FilteredCount == 0 ? 0 : (_currentPage - 1) * PageSize + 1;
    private int PageEnd => Math.Min(_currentPage * PageSize, FilteredCount);

    private List<AdminProductItem> PagedProducts =>
        FilteredProducts.Skip((_currentPage - 1) * PageSize).Take(PageSize).ToList();

    private void PrevPage() { if (_currentPage > 1) _currentPage--; }
    private void NextPage() { if (_currentPage < TotalPages) _currentPage++; }
    private void SetPage(int page) => _currentPage = page;

    private void OnEditItem(AdminProductItem item) => OnEdit.InvokeAsync(item);
    private void OnDeleteItem(AdminProductItem item) => OnDelete.InvokeAsync(item);
}






