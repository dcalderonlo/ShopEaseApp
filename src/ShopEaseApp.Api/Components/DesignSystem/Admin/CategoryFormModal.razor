@* Organism: Category create/edit form modal — glass-card *@
@if (Visible)
{
    <div class="fixed inset-0 z-[100] bg-surface/90 backdrop-blur-sm flex items-center justify-center p-4"
         @onclick="() => OnClose.InvokeAsync()">
        <div class="w-full max-w-md glass-card rounded-xl shadow-xl border border-outline-variant/30 p-lg"
             @onclick:stopPropagation="true">
            <h3 class="font-headline-md text-headline-md text-on-surface mb-lg">
                @(Category is null ? "Create Category" : "Edit Category")
            </h3>
            <div class="space-y-md">
                <div>
                    <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Name</label>
                    <input @bind="_name" @bind:event="oninput"
                           class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md mt-2"
                           placeholder="e.g. Electronics" type="text" />
                </div>
                <div>
                    <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Description</label>
                    <textarea @bind="_description" @bind:event="oninput"
                              class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md resize-none mt-2"
                              placeholder="Brief description..." rows="3"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-error font-body-md">@_error</p>
                }
                <div class="flex gap-sm justify-end pt-md border-t border-outline-variant">
                    <button class="px-md py-sm rounded-xl font-body-md text-on-surface-variant bg-surface-container-low border border-outline-variant"
                            @onclick="() => OnClose.InvokeAsync()">Cancel</button>
                    <button class="px-md py-sm rounded-xl font-body-md text-on-primary bg-primary"
                            @onclick="Save">@(Category is null ? "Create" : "Save")</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public AdminCategoryItem? Category { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private string _name = "";
    private string _description = "";
    private string? _error;
    private bool _loaded;

    protected override void OnParametersSet()
    {
        if (Visible && !_loaded)
        {
            if (Category is not null)
            {
                _name = Category.CategoryName;
                _description = Category.CategoryDescription ?? "";
            }
            else
            {
                _name = "";
                _description = "";
            }
            _error = null;
            _loaded = true;
        }
        if (!Visible) _loaded = false;
    }

    private async Task Save()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Name is required."; return; }

        if (Category is null)
            await CategoryHandler.CreateAsync(new CreateCategoryRequest(_name, _description));
        else
            await CategoryHandler.UpdateAsync(Category.CategoryId, new UpdateCategoryRequest(_name, _description));

        _loaded = false;
        await OnSaved.InvokeAsync();
    }

    [Inject] private CategoryHandler CategoryHandler { get; set; } = null!;
}
