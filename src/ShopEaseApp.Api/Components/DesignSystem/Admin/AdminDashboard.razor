@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@using ShopEaseApp.Api.Features.Admin.Dashboard
@using ShopEaseApp.Api.Features.Catalog.Categories
@using ShopEaseApp.Api.Components.DesignSystem.Atoms
@using ShopEaseApp.Api.Components.DesignSystem.Admin

<AdminSidebar CurrentPage="dashboard" />

<main class="lg:ml-64 min-h-screen transition-all pt-20 lg:pt-0">
    <div class="max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop py-lg">

        <div class="mb-lg">
            <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-xs">Dashboard</h2>
            <p class="text-on-surface-variant font-body-md">Welcome back. Here's your store at a glance.</p>
        </div>

        @if (_metrics is not null)
        {
            <div class="grid grid-cols-1 md:grid-cols-4 gap-md mb-xl">
                <StatCard Label="Total Products" Value="@_metrics.TotalProducts.ToString()"
                          Badge="@($"{_metrics.TotalSkus} SKUs")"
                          BadgeClass="bg-tertiary-fixed text-on-tertiary-fixed-variant" />
                <StatCard Label="Low Stock Items" Value="@_metrics.LowStockItems.ToString()"
                          ValueClass="text-secondary"
                          Badge="Action Required"
                          BadgeClass="bg-error-container text-on-error-container" />
                <StatCard Label="Inventory Value" Value="@($"${_metrics.InventoryValue:N0}")"
                          Class="bg-primary text-on-primary" ValueClass="text-on-primary" />
                <StatCard Label="Categories" Value="@_categoryCount.ToString()" ValueClass="text-tertiary" />
            </div>
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
            <a href="/admin/products"
               class="raised-card bg-surface p-lg rounded-lg border border-outline-variant/30
                      flex items-center gap-md hover:border-primary transition-colors">
                <div class="w-14 h-14 bg-primary-container rounded-xl flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-3xl">inventory_2</span>
                </div>
                <div>
                    <h3 class="font-headline-md text-headline-md text-on-surface">Products</h3>
                    <p class="text-on-surface-variant font-body-md">Manage inventory and pricing</p>
                </div>
                <span class="material-symbols-outlined ml-auto text-outline">arrow_forward</span>
            </a>

            <a href="/admin/categories"
               class="raised-card bg-surface p-lg rounded-lg border border-outline-variant/30
                      flex items-center gap-md hover:border-primary transition-colors">
                <div class="w-14 h-14 bg-tertiary-container rounded-xl flex items-center justify-center text-on-tertiary-container">
                    <span class="material-symbols-outlined text-3xl">category</span>
                </div>
                <div>
                    <h3 class="font-headline-md text-headline-md text-on-surface">Categories</h3>
                    <p class="text-on-surface-variant font-body-md">Organize your product catalog</p>
                </div>
                <span class="material-symbols-outlined ml-auto text-outline">arrow_forward</span>
            </a>
        </div>

        <footer class="w-full py-lg mt-xl flex justify-center border-t border-outline-variant/30">
            <span class="font-label-sm text-label-sm text-on-surface-variant">© 2026 EasyShop. Energetic Simplicity.</span>
        </footer>
    </div>
</main>

@code {
    private DashboardResponse? _metrics;
    private int _categoryCount;

    protected override async Task OnInitializedAsync()
    {
        _metrics = await Handler.GetMetricsAsync();
        _categoryCount = (await CatHandler.GetAllAsync()).Count();
        StateHasChanged();
    }

    [Inject] private AdminDashboardHandler Handler { get; set; } = null!;
    [Inject] private CategoryHandler CatHandler { get; set; } = null!;
}
