@page "/forgot-password"
@attribute [AllowAnonymous]

<div class="flex flex-col items-center justify-center min-h-screen p-4 md:p-8">

    <div class="fixed top-0 right-0 p-lg pointer-events-none opacity-20">
        <span class="material-symbols-outlined text-[120px] text-tertiary">lock_reset</span>
    </div>

    <main class="w-full max-w-md z-10">
        <div class="glass-card rounded-lg p-8 md:p-12 border border-surface-variant/30
                    flex flex-col items-center">

            @* Lock icon *@
            <div class="w-32 h-32 mb-8 relative">
                <div class="absolute inset-0 bg-primary/10 rounded-full animate-pulse"></div>
                <div class="relative z-10 w-full h-full flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined !text-[64px]" style="font-variation-settings: 'FILL' 1;">
                        lock_reset
                    </span>
                </div>
                <div class="absolute top-0 -right-2 w-4 h-4 bg-secondary-container rounded-full"></div>
                <div class="absolute bottom-2 -left-2 w-6 h-6 bg-tertiary-fixed-dim rounded-full opacity-60"></div>
            </div>

            <h1 class="font-headline-md text-headline-md text-on-surface mb-4 text-center">
                Forgot Password?
            </h1>

            <p class="font-body-md text-on-surface-variant text-center mb-8 px-4">
                Enter your email address and we'll send you a link to reset your password.
            </p>

            @if (_showSuccess)
            {
                <div class="w-20 h-20 bg-tertiary-container rounded-full flex items-center
                            justify-center text-on-tertiary-container mx-auto mb-6">
                    <span class="material-symbols-outlined !text-[40px]" style="font-variation-settings: 'FILL' 1;">
                        check_circle
                    </span>
                </div>
                <h2 class="font-headline-md mb-2">Check your email</h2>
                <p class="font-body-md text-on-surface-variant text-center mb-8">
                    We've sent recovery instructions to your inbox.
                </p>
                <a href="/login"
                   class="w-full bg-surface-container-highest text-on-surface py-3 rounded-full
                          font-label-sm text-center transition-all hover:bg-surface-variant">
                    Back to Login
                </a>
            }
            else
            {
                <form class="w-full space-y-6"
                      onsubmit="event.preventDefault(); this.querySelector('button').click();">

                    <div>
                        <label class="block font-label-sm text-label-sm text-outline mb-2 ml-1"
                               for="email">Email Address</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center
                                        pointer-events-none text-outline">
                                <span class="material-symbols-outlined">mail</span>
                            </div>
                            <input @bind="_email" @bind:event="oninput"
                                   class="w-full pl-12 pr-4 py-4 bg-surface-container-low
                                          border border-outline-variant rounded-xl
                                          focus:ring-0 focus:border-primary font-body-md
                                          placeholder:text-outline-variant transition-all"
                                   id="email" placeholder="name@example.com" type="email" />
                        </div>
                    </div>

                    <button type="button" disabled="@_isSubmitting"
                            class="w-full bg-primary text-on-primary py-4 rounded-full
                                   font-semibold shadow-lg hover:shadow-primary/20
                                   hover:scale-[1.02] active:scale-95
                                   transition-all duration-200 flex items-center justify-center gap-2"
                            @onclick="HandleSubmit">
                        @if (_isSubmitting)
                        {
                            <span class="material-symbols-outlined animate-spin">progress_activity</span>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Send Reset Link</span>
                            <span class="material-symbols-outlined">arrow_forward</span>
                        }
                    </button>
                </form>
            }

            <a href="/login"
               class="mt-8 flex items-center gap-2 text-primary font-label-sm hover:underline
                      hover:underline-offset-4 transition-all">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                Back to Login
            </a>
        </div>

        <footer class="mt-8 pb-12 flex flex-wrap justify-center gap-4
                        font-label-sm text-label-sm text-on-surface-variant">
            <a class="hover:text-primary transition-colors" href="#">Privacy Policy</a>
            <a class="hover:text-primary transition-colors" href="#">Terms of Service</a>
            <a class="hover:text-primary transition-colors" href="#">Shipping Info</a>
            <a class="hover:text-primary transition-colors" href="#">Contact Us</a>
        </footer>
        <p class="text-center font-label-sm text-label-sm text-outline">
            © 2026 EasyShop. Energetic Simplicity.
        </p>
    </main>
</div>

@code {
    private string _email = "";
    private bool _isSubmitting;
    private bool _showSuccess;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_email)) return;

        _isSubmitting = true;
        StateHasChanged();

        // Simulate sending email (no SMTP configured yet)
        await Task.Delay(1500);

        _isSubmitting = false;
        _showSuccess = true;
    }
}
