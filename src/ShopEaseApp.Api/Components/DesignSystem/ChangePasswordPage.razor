@page "/change-password"
@* @attribute [Authorize] *@
@using ShopEaseApp.Api.Features.Identity.ChangePassword
@using Microsoft.AspNetCore.Identity
@using ShopEaseApp.Api.Infrastructure.Data

<div class="min-h-screen flex flex-col"
     style="background: linear-gradient(135deg, #fcf9f8 0%, #dde1ff 100%);">

    @* Floating blobs *@
    <div class="absolute top-20 left-10 w-32 h-32 bg-primary/5 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-64 h-64 bg-secondary-container/10 rounded-full blur-3xl animate-bounce" style="animation-duration: 8s;"></div>

    <main class="flex-grow flex items-center justify-center px-margin-mobile py-xl relative">

        <section class="w-full max-w-md relative z-10">

            <div class="text-center mb-base space-y-1">
                <p class="font-label-sm text-label-sm uppercase tracking-widest text-outline">
                    Energetic Simplicity
                </p>
            </div>

            <div class="glass-card shadow-lg rounded-lg p-margin-mobile md:p-gutter flex flex-col items-center">

                <div class="w-16 h-16 bg-primary-container/10 rounded-full flex items-center justify-center mb-md">
                    <span class="material-symbols-outlined !text-[40px] text-primary">lock_reset</span>
                </div>

                <h1 class="font-headline-md text-headline-md text-on-surface mb-xl text-center">
                    Change Password
                </h1>

                <EditForm Model="@_model" OnValidSubmit="HandleChange"
                          class="w-full space-y-gutter" FormName="changePasswordForm">

                    @* Current Password *@
                    <div>
                        <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs ml-1"
                               for="current-password">Current Password</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2
                                         -translate-y-1/2 text-outline">lock</span>
                            <input @bind-value="_model.CurrentPassword" @bind-value:event="oninput"
                                   class="w-full py-4 bg-surface-container-low border-transparent
                                          focus:border-primary focus:ring-4 focus:ring-primary/10
                                          rounded-xl font-body-md transition-all outline-none pl-12"
                                   id="current-password" placeholder="••••••••" type="password" />
                        </div>
                    </div>

                    @* New Password *@
                    <div>
                        <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs ml-1"
                               for="new-password">New Password</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2
                                         -translate-y-1/2 text-outline">password</span>
                            <input @bind-value="_model.NewPassword" @bind-value:event="oninput"
                                   class="w-full py-4 bg-surface-container-low border-transparent
                                          focus:border-primary focus:ring-4 focus:ring-primary/10
                                          rounded-xl font-body-md transition-all outline-none pl-12"
                                   id="new-password" placeholder="••••••••" type="password" />
                        </div>
                        <p class="mt-2 text-[10px] text-outline ml-1">
                            Must be at least 6 characters long.
                        </p>
                    </div>

                    @* Confirm New Password *@
                    <div>
                        <label class="block font-label-sm text-label-sm text-on-surface-variant mb-xs ml-1"
                               for="confirm-password">Confirm New Password</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2
                                         -translate-y-1/2 text-outline">verified_user</span>
                            <input @bind-value="_confirmPassword" @bind-value:event="oninput"
                                   class="w-full py-4 bg-surface-container-low border-transparent
                                          focus:border-primary focus:ring-4 focus:ring-primary/10
                                          rounded-xl font-body-md transition-all outline-none pl-12"
                                   id="confirm-password" placeholder="••••••••" type="password" />
                        </div>
                    </div>

                    <button type="submit"
                            class="w-full py-4 bg-primary text-on-primary font-semibold rounded-xl
                                   flex items-center justify-center gap-2
                                   shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30
                                   transition-all duration-300 active:scale-95 mt-md">
                        <span>Update Password</span>
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                </EditForm>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-error font-body-md mt-md text-center">@_error</p>
                }

                @if (_success)
                {
                    <p class="text-tertiary font-body-md mt-md text-center">
                        Password changed! Redirecting...
                    </p>
                }
            </div>

            @* Security notice *@
            <div class="mt-xl flex items-center justify-center gap-4 px-4 opacity-70">
                <span class="material-symbols-outlined text-outline">security</span>
                <p class="text-label-sm text-outline font-label-sm leading-tight">
                    Your security is our priority. Changing your password will invalidate all active sessions.
                </p>
            </div>
        </section>
    </main>
</div>

@code {
    private sealed class ChangePasswordForm
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
    }

    private readonly ChangePasswordForm _model = new();
    private string _confirmPassword = "";
    private string? _error;
    private bool _success;

    private async Task HandleChange()
    {
        _error = null;

        if (_model.NewPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        if (_model.NewPassword.Length < 6)
        {
            _error = "Password must be at least 6 characters.";
            return;
        }

        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            _error = "Not authenticated.";
            return;
        }

        var (success, error) = await Handler.HandleAsync(
            user, new ChangePasswordRequest(_model.CurrentPassword, _model.NewPassword));

        if (success)
        {
            _success = true;
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            _error = error;
        }
    }

    [Inject] private ChangePasswordHandler Handler { get; set; } = null!;
    [Inject] private NavigationManager Nav { get; set; } = null!;
    [Inject] private UserManager<AppUser> UserManager { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = null!;
}
