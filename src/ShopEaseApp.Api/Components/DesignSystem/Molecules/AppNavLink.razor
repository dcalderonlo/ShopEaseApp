@* Molecule: Sidebar navigation link *@
<a href="@Href"
   class="flex items-center gap-md px-md py-sm transition-all duration-200 ease-in-out
          @(Active
              ? "text-primary font-bold border-r-4 border-primary hover:bg-surface-variant"
              : "text-on-surface-variant hover:bg-surface-variant")">
    <span class="material-symbols-outlined"
          style="@(Active ? "font-variation-settings: 'FILL' 1;" : "")">@Icon</span>
    <span class="font-body-md text-body-md">@Label</span>
</a>

@code {
    [Parameter] public string Href { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public bool Active { get; set; }
}
