@* Organism: Admin sidebar navigation panel
<nav class="hidden lg:flex flex-col h-screen fixed left-0 top-0 py-md px-sm z-40
            bg-surface-container w-64 shadow-md transition-all bottom-0">
    <div class="mb-xl px-sm">
        <h1 class="font-display-lg-mobile text-display-lg-mobile font-bold text-primary mb-xs">Admin Panel</h1>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Stock Management</p>
    </div>

    <div class="flex-1 space-y-2">
        <AdminNavLink Href="/admin" Icon="dashboard" Label="Dashboard"
                      Active="@(CurrentPage == "dashboard")" />
        <AdminNavLink Href="/admin/products" Icon="inventory_2" Label="Inventory"
                      Active="@(CurrentPage == "inventory")" />
        <AdminNavLink Href="/admin/categories" Icon="category" Label="Categories"
                      Active="@(CurrentPage == "categories")" />
        <AdminNavLink Href="#" Icon="settings" Label="Settings" />
    </div>

    <div class="mt-auto px-sm pt-md border-t border-outline-variant/30">
        <div class="mt-md flex items-center gap-sm justify-between">
            <div class="flex items-center gap-sm">
                <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">person</span>
                </div>
                <div class="overflow-hidden">
                    <p class="font-label-sm text-label-sm font-bold truncate">Admin</p>
                    <p class="text-[10px] text-on-surface-variant uppercase truncate">Store Manager</p>
                </div>
            </div>
            <a href="/logout"
               class="p-2 text-on-surface-variant hover:text-error hover:bg-error-container/10 rounded-full transition-all"
               title="Logout">
                <span class="material-symbols-outlined">logout</span>
            </a>
        </div>
    </div>
</nav>

