@* Organism: Admin sidebar navigation panel *@
@using ShopEaseApp.Api.Components.DesignSystem.Molecules

<aside class="hidden lg:flex flex-col h-screen fixed left-0 top-0 py-md px-sm z-50
              bg-surface-container-low w-64 shadow-sm">

    <div class="mb-xl px-sm">
        <h1 class="font-headline-md text-headline-md font-bold text-primary">EaseShop</h1>
        <p class="font-label-sm text-label-sm text-outline uppercase tracking-widest mt-xs">Admin Console</p>
    </div>

    <nav class="flex-1 space-y-xs">
        <AppNavLink Href="/admin"             Icon="dashboard"     Label="Dashboard"   Active="@(CurrentPage == "dashboard")" />
        <AppNavLink Href="/admin/products"    Icon="inventory_2"   Label="Products"    Active="@(CurrentPage == "inventory")" />
        <AppNavLink Href="/admin/categories"  Icon="category"      Label="Categories"  Active="@(CurrentPage == "categories")" />
        <AppNavLink Href="#"                  Icon="shopping_cart"  Label="Orders"     Active="@(CurrentPage == "orders")" />
        <AppNavLink Href="#"                  Icon="group"         Label="Users"       Active="@(CurrentPage == "users")" />
    </nav>

    <div class="mt-auto space-y-xs pb-md">
        <AppNavLink Href="#"        Icon="settings" Label="Settings" Active="@(CurrentPage == "settings")" />
        <AppNavLink Href="/logout"  Icon="logout"   Label="Logout" />
    </div>
</aside>

@* Mobile top bar *@
<header class="lg:hidden fixed top-0 left-0 w-full z-50 flex justify-between items-center
               px-margin-mobile h-20 bg-surface/80 backdrop-blur-md border-b border-outline-variant">
    <span class="font-display-lg-mobile text-display-lg-mobile font-bold text-primary">EasyShop</span>
    <button class="p-2 text-on-surface">
        <span class="material-symbols-outlined">menu</span>
    </button>
</header>

@code {
    [Parameter] public string CurrentPage { get; set; } = "dashboard";
}








