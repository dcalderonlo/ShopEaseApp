@inject ProductHandler Products
@inject CategoryHandler Categories
@inject IWebHostEnvironment Env

@if (Visible)
{
    <div class="fixed inset-0 z-[100] bg-surface/90 backdrop-blur-sm flex items-center justify-center p-4"
         @onclick="Cancel">
        <div class="w-full max-w-5xl max-h-[90vh] overflow-y-auto glass-card rounded-xl shadow-xl border border-outline-variant/30"
             @onclick:stopPropagation="true">

            <div class="p-lg">
                <div class="flex items-center justify-between mb-lg">
                    <div class="space-y-xs">
                        <h2 class="font-display-lg text-display-lg-mobile md:font-display-lg text-on-surface">
                            @(Product is null ? "Create New Product" : "Edit Product")
                        </h2>
                        <p class="text-on-surface-variant font-body-md opacity-70">
                            @(Product is null ? "Define a new offering for your catalog." : $"Editing: {Product.ProductName}")
                        </p>
                    </div>
                    <button class="p-2 text-on-surface-variant hover:text-error rounded-full transition-all"
                            @onclick="Cancel">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
                    @* Left column: Main details *@
                    <div class="lg:col-span-2 space-y-gutter">
                        <div class="bg-surface-container-lowest p-md rounded-lg shadow-sm space-y-md">
                            <h3 class="font-headline-md text-headline-md text-on-surface border-b border-outline-variant/30 pb-base">
                                General Information
                            </h3>
                            <div class="space-y-base">
                                <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Product Name</label>
                                <input @bind="_name" @bind:event="oninput"
                                       class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md"
                                       placeholder="e.g. Minimalist Ceramic Lamp" type="text" />
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                                <div class="space-y-base">
                                    <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Category</label>
                                    <select @bind="_categoryId"
                                            class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md bg-surface-container-low">
                                        <option value="0">Select a category...</option>
                                        @foreach (var cat in _categories)
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="space-y-base">
                                <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Description</label>
                                <textarea @bind="_description" @bind:event="oninput"
                                          class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md resize-none"
                                          placeholder="Describe the craftsmanship, materials, and unique selling points..."
                                          rows="6"></textarea>
                            </div>
                        </div>

                        @* Inventory & Pricing (create mode only) *@
                        @if (Product is null)
                        {
                            <div class="bg-surface-container-lowest p-md rounded-lg shadow-sm space-y-md">
                                <h3 class="font-headline-md text-headline-md text-on-surface border-b border-outline-variant/30 pb-base">
                                    Inventory &amp; Pricing
                                </h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                                    <div class="space-y-base">
                                        <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Price ($)</label>
                                        <div class="relative">
                                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline font-body-md">$</span>
                                            <input @bind="_price" @bind:event="oninput"
                                                   class="w-full p-md pl-8 border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md"
                                                   placeholder="0.00" type="number" step="0.01" min="0" />
                                        </div>
                                    </div>
                                    <div class="space-y-base">
                                        <label class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Stock Quantity</label>
                                        <input @bind="_stock" @bind:event="oninput"
                                               class="w-full p-md border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-all font-body-md"
                                               placeholder="0" type="number" min="0" />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @* Right column: Media & Actions *@
                    <div class="space-y-gutter">
                        <div class="bg-surface-container-lowest p-md rounded-lg shadow-sm space-y-md">
                            <h3 class="font-headline-md text-headline-md text-on-surface border-b border-outline-variant/30 pb-base">
                                Product Image
                            </h3>
                            <label class="group relative aspect-square w-full rounded-lg border-2 border-dashed border-outline-variant bg-surface-container-low flex flex-col items-center justify-center cursor-pointer overflow-hidden hover:border-primary transition-colors duration-300">
                                <div class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity bg-primary"></div>
                                <InputFile class="hidden" accept=".jpg,.jpeg,.png,.webp"
                                           OnChange="HandleFileSelected" />
                                @if (!string.IsNullOrEmpty(_previewUrl))
                                {
                                    <img src="@_previewUrl" class="absolute inset-0 w-full h-full object-cover rounded-lg" />
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-outline text-4xl group-hover:text-primary transition-colors">add_photo_alternate</span>
                                    <p class="font-label-sm text-label-sm text-on-surface-variant mt-sm">Click to upload or drag image</p>
                                    <p class="text-[10px] text-outline mt-xs">PNG, JPG up to 10MB</p>
                                }
                                <div class="absolute -bottom-4 -right-4 w-32 h-32 rounded-full bg-primary/5 blur-2xl"></div>
                            </label>
                            @if (_isUploading)
                            {
                                <p class="text-on-surface-variant font-label-sm text-center">
                                    <span class="material-symbols-outlined animate-spin text-sm">progress_activity</span> Uploading...
                                </p>
                            }
                            @* Thumbnail carousel *@
                            <div class="space-y-md">
                                <div class="relative flex items-center group/carousel">
                                    <button class="absolute left-0 z-10 p-1 bg-surface-container-lowest/80 rounded-full shadow-sm border border-outline-variant/30 hover:bg-primary hover:text-on-primary transition-all opacity-0 group-hover/carousel:opacity-100 -translate-x-1/2"
                                            @onclick="PrevImage">
                                        <span class="material-symbols-outlined text-body-md">chevron_left</span>
                                    </button>
                                    <div class="flex-1 flex gap-sm overflow-x-auto scrollbar-hide py-1 px-1">
                                        @if (_imageUrls.Count > 0)
                                        {
                                            @foreach (var url in _imageUrls.Select((url, idx) => new { url, idx }))
                                            {
                                                <div class="flex-shrink-0 w-16 aspect-square bg-surface-container-low rounded-lg border @(_selectedImageIdx == url.idx ? "border-2 border-primary" : "border border-outline-variant/30") flex items-center justify-center cursor-pointer hover:border-primary/50 transition-colors"
                                                     @onclick="() => _selectedImageIdx = url.idx">
                                                    <img src="@url.url" class="w-full h-full object-cover rounded-lg" />
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="flex-shrink-0 w-16 aspect-square bg-surface-container-low rounded-lg border border-outline-variant/30 flex items-center justify-center">
                                                <span class="material-symbols-outlined text-outline-variant">image</span>
                                            </div>
                                        }
                                        <label class="flex-shrink-0 w-16 aspect-square bg-surface-container-low rounded-lg border border-dashed border-outline-variant/30 flex items-center justify-center cursor-pointer hover:bg-surface-container transition-colors">
                                            <InputFile class="hidden" accept=".jpg,.jpeg,.png,.webp" OnChange="HandleFileSelected" />
                                            <span class="material-symbols-outlined text-outline-variant">add</span>
                                        </label>
                                    </div>
                                    <button class="absolute right-0 z-10 p-1 bg-surface-container-lowest/80 rounded-full shadow-sm border border-outline-variant/30 hover:bg-primary hover:text-on-primary transition-all opacity-0 group-hover/carousel:opacity-100 translate-x-1/2"
                                            @onclick="NextImage">
                                        <span class="material-symbols-outlined text-body-md">chevron_right</span>
                                    </button>
                                </div>
                                @if (_imageUrls.Count > 0)
                                {
                                    <div class="flex justify-center gap-xs">
                                        @for (int i = 0; i < _imageUrls.Count; i++)
                                        {
                                            <div class="w-2 h-2 rounded-full @(i == _selectedImageIdx ? "bg-primary" : "bg-outline-variant/50")"></div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* Error message *@
                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-error font-body-md mt-md text-center">@_error</p>
                }

                @* Actions *@
                <div class="flex gap-sm justify-end mt-md pt-md border-t border-outline-variant">
                    <button class="px-md py-sm rounded-xl font-body-md text-on-surface-variant bg-surface-container-low border border-outline-variant hover:bg-surface-container transition-all active:scale-95"
                            @onclick="Cancel">Cancel</button>
                    <button class="px-md py-sm rounded-xl font-body-md text-on-primary bg-primary shadow-lg shadow-primary/20 hover:shadow-xl hover:translate-y-[-2px] transition-all active:scale-95"
                            @onclick="Save" disabled="@_isSaving">
                        @(_isSaving ? "Saving..." : (Product is null ? "Create Product" : "Save Changes"))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public AdminProductResponse? Product { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private string _name = "";
    private string? _description;
    private int _categoryId;
    private string _imageUrlsText = "";
    private decimal _price;
    private int _stock;
    private string? _error;
    private bool _isSaving;
    private bool _isUploading;
    private string? _previewUrl;
    private int _selectedImageIdx;
    private List<CategoryResponse> _categories = [];
    private bool _loaded;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !_loaded)
        {
            _categories = (await Categories.GetAllAsync()).ToList();

            if (Product is not null)
            {
                var full = await Products.GetByIdAsync(Product.ProductId);
                if (full is not null)
                {
                    _name = full.Name;
                    _description = full.Description;
                    _categoryId = full.CategoryId;
                    _imageUrlsText = string.Join(", ", full.ImageUrls);
                }
            }
            else
            {
                _name = "";
                _description = null;
                _categoryId = 0;
                _imageUrlsText = "";
                _price = 0;
                _stock = 0;
            }
            _error = null;
            _loaded = true;
        }

        if (!Visible) _loaded = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 10 * 1024 * 1024)
        {
            _error = "File exceeds 10 MB limit.";
            return;
        }

        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext is not ".jpg" and not ".jpeg" and not ".png" and not ".webp")
        {
            _error = "Only JPG, PNG, WebP allowed.";
            return;
        }

        _isUploading = true;
        StateHasChanged();

        var uploadsDir = Path.Combine(Env.WebRootPath ?? Path.Combine(Directory.GetCurrentDirectory(), "wwwroot"), "uploads");
        Directory.CreateDirectory(uploadsDir);

        var fileName = $"{Guid.NewGuid()}{ext}";
        var filePath = Path.Combine(uploadsDir, fileName);

        await using var stream = File.Create(filePath);
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);

        var url = $"/uploads/{fileName}";

        if (string.IsNullOrWhiteSpace(_imageUrlsText))
            _imageUrlsText = url;
        else
            _imageUrlsText += ", " + url;

        _previewUrl = url;
        _selectedImageIdx = _imageUrls.Count - 1;
        _isUploading = false;
        _error = null;
        StateHasChanged();
    }

    private List<string> _imageUrls =>
        _imageUrlsText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private void PrevImage()
    {
        if (_imageUrls.Count > 0)
            _selectedImageIdx = (_selectedImageIdx - 1 + _imageUrls.Count) % _imageUrls.Count;
    }

    private void NextImage()
    {
        if (_imageUrls.Count > 0)
            _selectedImageIdx = (_selectedImageIdx + 1) % _imageUrls.Count;
    }

    private void Cancel()
    {
        _loaded = false;
        OnClose.InvokeAsync();
    }

    private async Task Save()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _error = "Product name is required.";
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (Product is null)
            {
                @* Create new product *@
                var urls = _imageUrlsText
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                var request = new CreateProductRequest(
                    _name, _description, _categoryId, urls,
                    [_price > 0 || _stock > 0
                        ? new CreateVariantRequest("Default", _price, _stock)
                        : new CreateVariantRequest("Default", 0, 0)]);

                var (success, response, error) = await Products.CreateAsync(request);
                if (!success)
                    _error = error ?? "Failed to create product.";
            }
            else
            {
                var urls = _imageUrlsText
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                var (success, _, error) = await Products.UpdateAsync(
                    Product.ProductId,
                    new UpdateProductRequest(_name, _description, _categoryId, urls));

                if (!success)
                    _error = error ?? "Failed to update product.";
            }

            if (_error is null)
            {
                _loaded = false;
                await OnSaved.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
}
