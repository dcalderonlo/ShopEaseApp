@inject ProductHandler Products
@inject CategoryHandler Categories

@if (Visible && Product is not null)
{
    <div class="modal-overlay">
        <div class="modal">
            <h3>Edit Product</h3>
            <p>Editing: <strong>@Product.ProductName</strong></p>

            <label>Name</label>
            <input @bind="_name" />

            <label>Description</label>
            <textarea @bind="_description"></textarea>

            <label>Category</label>
            <select @bind="_categoryId">
                @foreach (var cat in _categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>

            <label>Image URLs (comma separated)</label>
            <input @bind="_imageUrlsText" />

            <button @onclick="Save">Save</button>
            <button @onclick="Cancel">Cancel</button>
        </div>
    </div>
}

@code {
    [Parameter] public AdminProductResponse? Product { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private string _name = string.Empty;
    private string? _description;
    private int _categoryId;
    private string _imageUrlsText = string.Empty;
    private List<CategoryResponse> _categories = [];
    private bool _loaded;

    // Load the full product + categories only when the modal becomes visible.
    // AdminProductResponse is a flat per-variant row and lacks Description,
    // CategoryId, and ImageUrls, so we hydrate from ProductHandler.GetByIdAsync.
    protected override async Task OnParametersSetAsync()
    {
        if (Visible && Product is not null && !_loaded)
        {
            var full = await Products.GetByIdAsync(Product.ProductId);
            if (full is not null)
            {
                _name = full.Name;
                _description = full.Description;
                _categoryId = full.CategoryId;
                _imageUrlsText = string.Join(",", full.ImageUrls);
            }
            _categories = (await Categories.GetAllAsync()).ToList();
            _loaded = true;
        }

        if (!Visible)
            _loaded = false;
    }

    private void Cancel()
    {
        _loaded = false;
        OnClose.InvokeAsync();
    }

    private async Task Save()
    {
        if (Product is null) return;

        var urls = _imageUrlsText
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        await Products.UpdateAsync(Product.ProductId,
            new UpdateProductRequest(_name, _description, _categoryId, urls));

        _loaded = false;
        await OnSaved.InvokeAsync();
    }
}
