@using Microsoft.AspNetCore.Components.Web
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    @* Google Fonts *@
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Quicksand:wght@600;700&display=swap" rel="stylesheet" />

    @* Material Symbols *@
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    @* Custom CSS *@
    <link href="css/easeshop.css" rel="stylesheet" />

    @* Tailwind CDN *@
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "tertiary-container": "#007c61",
                        "outline-variant": "#c4c5d9",
                        "secondary-container": "#fd7d6c",
                        "on-tertiary": "#ffffff",
                        "primary-fixed": "#dde1ff",
                        "surface-container-highest": "#e5e2e1",
                        "primary": "#0040e0",
                        "inverse-primary": "#b8c3ff",
                        "secondary": "#a43b2f",
                        "on-primary": "#ffffff",
                        "surface-bright": "#fcf9f8",
                        "surface-container": "#f0eded",
                        "error": "#ba1a1a",
                        "on-error": "#ffffff",
                        "surface-container-lowest": "#ffffff",
                        "surface": "#fcf9f8",
                        "surface-dim": "#dcd9d9",
                        "on-secondary-fixed-variant": "#84241a",
                        "on-primary-fixed-variant": "#0035be",
                        "inverse-on-surface": "#f3f0ef",
                        "primary-fixed-dim": "#b8c3ff",
                        "on-background": "#1c1b1b",
                        "on-error-container": "#93000a",
                        "tertiary-fixed-dim": "#4fddb4",
                        "outline": "#747688",
                        "on-surface-variant": "#434656",
                        "on-primary-fixed": "#001356",
                        "tertiary": "#00614b",
                        "surface-variant": "#e5e2e1",
                        "surface-tint": "#124af0",
                        "on-secondary": "#ffffff",
                        "on-surface": "#1c1b1b",
                        "secondary-fixed-dim": "#ffb4a9",
                        "on-tertiary-fixed": "#002117",
                        "on-tertiary-container": "#b7ffe4",
                        "on-secondary-container": "#71160f",
                        "surface-container-low": "#f6f3f2",
                        "secondary-fixed": "#ffdad5",
                        "surface-container-high": "#eae7e7",
                        "on-tertiary-fixed-variant": "#00513e",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed": "#410000",
                        "tertiary-fixed": "#70facf",
                        "primary-container": "#2e5bff",
                        "background": "#fcf9f8",
                        "on-primary-container": "#efefff",
                        "inverse-surface": "#313030"
                    },
                    borderRadius: {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    spacing: {
                        "base": "8px",
                        "gutter": "24px",
                        "lg": "48px",
                        "xs": "4px",
                        "margin-desktop": "64px",
                        "sm": "12px",
                        "margin-mobile": "16px",
                        "md": "24px",
                        "xl": "80px"
                    },
                    fontFamily: {
                        "body-lg": ["Montserrat"],
                        "label-sm": ["Montserrat"],
                        "body-md": ["Montserrat"],
                        "display-lg": ["Quicksand"],
                        "display-lg-mobile": ["Quicksand"],
                        "headline-md": ["Quicksand"]
                    },
                    fontSize: {
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "label-sm": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "display-lg-mobile": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "700" }],
                        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }]
                    }
                }
            }
        }
    </script>

    <HeadOutlet @rendermode="@RenderMode.InteractiveServer" />
</head>
<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="@RenderMode.InteractiveServer" />
    </CascadingAuthenticationState>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
